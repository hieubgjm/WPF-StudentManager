<Window x:Class="QuanLySinhVien.Views.DoiMatKhauWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu"
        Height="330" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Mật khẩu hiện tại" Margin="0,0,0,4" />
        <PasswordBox x:Name="txtMatKhauCu" Margin="0,0,0,12" />

        <TextBlock Text="Mật khẩu mới" Margin="0,0,0,4" />
        <PasswordBox x:Name="txtMatKhauMoi" Margin="0,0,0,12" />

        <TextBlock Text="Nhập lại mật khẩu mới" Margin="0,0,0,4" />
        <PasswordBox x:Name="txtNhapLaiMatKhauMoi" Margin="0,0,0,4" />

        <TextBlock x:Name="lblThongBao"
                    Foreground="{StaticResource MauNguyHiem}"
                    TextWrapping="Wrap"
                    Margin="0,8,0,0"
                    Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Style="{StaticResource NutPhu}" Width="90" Margin="0,0,8,0"
                    Click="btnHuy_Click" />
            <Button Content="Lưu" Style="{StaticResource NutChinh}" Width="90"
                    Click="btnLuu_Click" />
        </StackPanel>
    </StackPanel>
</Window>
