<Window x:Class="QuanLySinhVien.Views.ThemSuaMonHocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm môn học"
        Height="420" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Mã môn học" Margin="0,0,0,4" />
            <TextBox x:Name="txtMaMonHoc" Margin="0,0,0,12" />

            <TextBlock Text="Tên môn học" Margin="0,0,0,4" />
            <TextBox x:Name="txtTenMonHoc" Margin="0,0,0,12" />

            <TextBlock Text="Số tín chỉ" Margin="0,0,0,4" />
            <TextBox x:Name="txtSoTinChi" Margin="0,0,0,12" />

            <TextBlock Text="Ghi chú" Margin="0,0,0,4" />
            <TextBox x:Name="txtGhiChu" Height="60" TextWrapping="Wrap" AcceptsReturn="True" />

            <TextBlock x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                    Click="btnHuy_Click" />
            <Button Content="Lưu" Style="{StaticResource NutChinh}" Width="100"
                    Click="btnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
