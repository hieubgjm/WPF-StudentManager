<Window x:Class="QuanLySinhVien.Views.ThemSuaSinhVienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm sinh viên"
        Height="620" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <TextBlock Text="Mã sinh viên" Margin="0,0,0,4" />
            <TextBox x:Name="txtMaSV" Margin="0,0,0,12" />

            <TextBlock Text="Họ và tên" Margin="0,0,0,4" />
            <TextBox x:Name="txtHoTen" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ngày sinh" Margin="0,0,0,4" />
                    <DatePicker x:Name="dpNgaySinh" Height="32" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Giới tính" Margin="0,0,0,4" />
                    <ComboBox x:Name="cboGioiTinh">
                        <ComboBoxItem Content="Nam" />
                        <ComboBoxItem Content="Nữ" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <TextBlock Text="Địa chỉ" Margin="0,0,0,4" />
            <TextBox x:Name="txtDiaChi" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Số điện thoại" Margin="0,0,0,4" />
                    <TextBox x:Name="txtSoDienThoai" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Email" Margin="0,0,0,4" />
                    <TextBox x:Name="txtEmail" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Lớp" Margin="0,0,0,4" />
                    <ComboBox x:Name="cboLop" DisplayMemberPath="TenLop" SelectedValuePath="LopId" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ca học" Margin="0,0,0,4" />
                    <ComboBox x:Name="cboCaHoc" DisplayMemberPath="TenCa" SelectedValuePath="CaHocId" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Trạng thái học tập" Margin="0,0,0,4" />
            <ComboBox x:Name="cboTrangThai" Margin="0,0,0,12">
                <ComboBoxItem Content="Đang học" />
                <ComboBoxItem Content="Bảo lưu" />
                <ComboBoxItem Content="Tốt nghiệp" />
            </ComboBox>

            <TextBlock x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                    Click="btnHuy_Click" />
            <Button Content="Lưu" Style="{StaticResource NutChinh}" Width="100"
                    Click="btnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
