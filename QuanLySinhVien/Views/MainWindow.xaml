<Window x:Class="QuanLySinhVien.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QuanLySinhVien.Views"
        Title="Phần mềm Quản lý Sinh viên"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MauNen}">

    <DockPanel>

        <!-- Thanh trên cùng: tên phần mềm bên trái, thông tin người dùng + nút chức năng bên phải -->
        <Border DockPanel.Dock="Top" Background="{StaticResource MauChinh}" Padding="20,14">
            <Grid>
                <TextBlock Text="QUẢN LÝ SINH VIÊN"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblXinChao"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <Button Content="Đổi mật khẩu"
                            Style="{StaticResource NutPhu}"
                            Margin="0,0,8,0"
                            Click="btnDoiMatKhau_Click" />
                    <Button Content="Đăng xuất"
                            Style="{StaticResource NutXoa}"
                            Click="btnDangXuat_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Nội dung chính: mỗi tab là 1 UserControl riêng, tự lo việc CRUD của nó -->
        <TabControl Margin="16" Padding="4">
            <TabItem Header="Sinh viên">
                <views:SinhVienControl />
            </TabItem>
            <TabItem Header="Lớp học">
                <views:LopHocControl />
            </TabItem>
            <TabItem Header="Môn học">
                <views:MonHocControl />
            </TabItem>
            <TabItem Header="Bảng điểm">
                <views:DiemSoControl />
            </TabItem>
            <TabItem Header="Dashboard">
                <views:ThongKeControl />
            </TabItem>
            <!-- Tab quản lý tài khoản chỉ hiện với Admin, xem code-behind hàm KiemTraQuyenAdmin -->
            <TabItem x:Name="tabTaiKhoan" Header="Tài khoản">
                <views:TaiKhoanControl />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
