<Window x:Class="QuanLySinhVien.Views.ThemSuaCaHocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm ca học"
        Height="380" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Tên ca học" Margin="0,0,0,4" />
            <TextBox x:Name="txtTenCa" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Giờ bắt đầu (vd 07:00)" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <TextBox x:Name="txtGioBatDau" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Giờ kết thúc (vd 11:00)" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <TextBox x:Name="txtGioKetThuc" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Ghi chú" Margin="0,12,0,4" />
            <TextBox x:Name="txtGhiChu" Height="60" TextWrapping="Wrap" AcceptsReturn="True" />

            <TextBlock x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                    Click="btnHuy_Click" />
            <Button Content="Lưu" Style="{StaticResource NutChinh}" Width="100"
                    Click="btnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
