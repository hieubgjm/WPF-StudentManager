<UserControl x:Class="QuanLySinhVien.Views.ThongKeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 3 ô số liệu tổng quan -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="3" Margin="0,0,0,16">
            <Border Background="White" CornerRadius="8" Margin="0,0,8,0" Padding="16"
                    BorderBrush="#E0E4EC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tổng số sinh viên" Foreground="Gray" />
                    <TextBlock x:Name="lblTongSinhVien" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource MauChinh}" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Margin="8,0" Padding="16"
                    BorderBrush="#E0E4EC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tổng số lớp học" Foreground="Gray" />
                    <TextBlock x:Name="lblTongLop" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource MauChinh}" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Margin="8,0,0,0" Padding="16"
                    BorderBrush="#E0E4EC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tổng số ca học" Foreground="Gray" />
                    <TextBlock x:Name="lblTongCaHoc" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource MauChinh}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Bảng sĩ số từng lớp -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E4EC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="4,0,0,8">
                    <TextBlock Text="Sĩ số theo từng lớp" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="Làm mới" Style="{StaticResource NutPhu}"
                            HorizontalAlignment="Right" Click="btnLamMoi_Click" />
                </Grid>

                <DataGrid Grid.Row="1" x:Name="dgSiSoLop"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F7F9FC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Lớp" Binding="{Binding TenLop}" Width="*" />
                        <DataGridTextColumn Header="Sĩ số hiện tại" Binding="{Binding SiSoHienTai}" Width="130" />
                        <DataGridTextColumn Header="Sĩ số tối đa" Binding="{Binding SiSoToiDa}" Width="130" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
