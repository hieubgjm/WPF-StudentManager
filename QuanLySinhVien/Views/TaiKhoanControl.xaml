<UserControl x:Class="QuanLySinhVien.Views.TaiKhoanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Danh sách tài khoản đăng nhập" VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="{StaticResource MauChu}" />

            <Button Grid.Column="1" Content="Làm mới" Style="{StaticResource NutPhu}"
                    Margin="0,0,8,0" Click="btnLamMoi_Click" />
            <Button Grid.Column="2" Content="Thêm" Style="{StaticResource NutChinh}"
                    Margin="0,0,8,0" Click="btnThem_Click" />
            <Button Grid.Column="3" Content="Sửa" Style="{StaticResource NutChinh}"
                    Margin="0,0,8,0" Click="btnSua_Click" />
            <Button Grid.Column="4" Content="Đặt lại mật khẩu" Style="{StaticResource NutPhu}"
                    Margin="0,0,8,0" Click="btnDatLaiMatKhau_Click" />
            <Button Grid.Column="5" Content="Xóa" Style="{StaticResource NutXoa}"
                    Click="btnXoa_Click" />
        </Grid>

        <DataGrid Grid.Row="1" x:Name="dgTaiKhoan"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F7F9FC"
                  MouseDoubleClick="dgTaiKhoan_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding TenDangNhap}" Width="150" />
                <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="200" />
                <DataGridTextColumn Header="Vai trò" Binding="{Binding VaiTro}" Width="120" />
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThaiHienThi}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
