<Window x:Class="QuanLySinhVien.Views.DangNhapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - Quản lý Sinh viên"
        Height="420" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource MauNen}">
    <Grid>
        <Border Background="White"
                CornerRadius="10"
                Margin="24"
                Padding="28"
                BorderBrush="#E0E4EC"
                BorderThickness="1">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="QUẢN LÝ SINH VIÊN"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource MauChinh}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Đăng nhập để tiếp tục"
                           FontSize="12"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,24" />

                <TextBlock Text="Tên đăng nhập" Margin="0,0,0,4" />
                <TextBox x:Name="txtTenDangNhap" Margin="0,0,0,14" />

                <TextBlock Text="Mật khẩu" Margin="0,0,0,4" />
                <PasswordBox x:Name="txtMatKhau" Margin="0,0,0,4"
                             KeyDown="txtMatKhau_KeyDown" />

                <TextBlock x:Name="lblThongBao"
                           Foreground="{StaticResource MauNguyHiem}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="Collapsed" />

                <Button x:Name="btnDangNhap"
                        Content="ĐĂNG NHẬP"
                        Style="{StaticResource NutChinh}"
                        Margin="0,20,0,0"
                        Click="btnDangNhap_Click" />

                <TextBlock Text="Tài khoản mặc định: admin / 123456"
                           FontSize="11"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
