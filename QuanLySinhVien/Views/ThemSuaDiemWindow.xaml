<Window x:Class="QuanLySinhVien.Views.ThemSuaDiemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập điểm"
        Height="360" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Môn học" Margin="0,0,0,4" />
            <ComboBox x:Name="cboMonHoc" DisplayMemberPath="TenMonHoc" SelectedValuePath="MonHocId"
                      Margin="0,0,0,12" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Điểm giữa kỳ (0-10)" Margin="0,0,0,4" />
                    <TextBox x:Name="txtDiemGiuaKy" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Điểm cuối kỳ (0-10)" Margin="0,0,0,4" />
                    <TextBox x:Name="txtDiemCuoiKy" />
                </StackPanel>
            </Grid>

            <TextBlock x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                    Click="btnHuy_Click" />
            <Button Content="Lưu" Style="{StaticResource NutChinh}" Width="100"
                    Click="btnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
