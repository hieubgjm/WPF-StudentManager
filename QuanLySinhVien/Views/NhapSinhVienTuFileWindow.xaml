<Window x:Class="QuanLySinhVien.Views.NhapSinhVienTuFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập sinh viên từ file CSV"
        Height="640" Width="1050"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hướng dẫn + chọn file / xuất file mẫu -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock TextWrapping="Wrap" Foreground="Gray" VerticalAlignment="Center"
                       Text="File CSV gồm các cột: MaSV;HoTen;NgaySinh(dd/MM/yyyy);GioiTinh(Nam/Nữ);DiaChi;SoDienThoai;Email;MaLop;TenCaHoc;TrangThai. Có thể để trống DiaChi/SDT/Email/MaLop/TenCaHoc/TrangThai." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Xuất file mẫu..." Style="{StaticResource NutPhu}" Margin="0,0,8,0"
                        Click="btnXuatMau_Click" />
                <Button Content="Chọn file CSV..." Style="{StaticResource NutChinh}"
                        Click="btnChonFile_Click" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" x:Name="dgDanhSach"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionUnit="Cell"
                  AlternatingRowBackground="#F7F9FC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SV" Binding="{Binding MaSV}" Width="80" />
                <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen}" Width="150" />
                <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh}" Width="85" />
                <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="65" />
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="120" />
                <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai}" Width="95" />
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="130" />
                <DataGridTextColumn Header="Mã lớp" Binding="{Binding MaLop}" Width="80" />
                <DataGridTextColumn Header="Ca học" Binding="{Binding TenCaHoc}" Width="90" />
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="90" />
                <DataGridTextColumn Header="Kết quả kiểm tra" Binding="{Binding KetQua}" Width="*" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Đóng" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                        Click="btnDong_Click" />
                <Button Content="Nhập tất cả" Style="{StaticResource NutChinh}" Width="120"
                        Click="btnNhapTatCa_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
