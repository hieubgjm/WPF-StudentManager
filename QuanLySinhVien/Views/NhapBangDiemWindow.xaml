<Window x:Class="QuanLySinhVien.Views.NhapBangDiemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập bảng điểm theo lớp"
        Height="620" Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Chọn lớp + môn học để tải danh sách sinh viên cần nhập điểm -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lớp" Margin="0,0,0,4" />
                <ComboBox x:Name="cboLop" DisplayMemberPath="TenLop" SelectedValuePath="LopId" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Môn học" Margin="0,0,0,4" />
                <ComboBox x:Name="cboMonHoc" DisplayMemberPath="TenMonHoc" SelectedValuePath="MonHocId" />
            </StackPanel>

            <Button Grid.Column="4" Content="Tải danh sách" Style="{StaticResource NutChinh}"
                    VerticalAlignment="Bottom" Click="btnTaiDanhSach_Click" />
        </Grid>

        <!-- Nhập tay trực tiếp trên lưới, hoặc nhập từ file CSV (mã SV;điểm giữa kỳ;điểm cuối kỳ) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Gõ trực tiếp điểm giữa kỳ/cuối kỳ vào lưới bên dưới, hoặc nhập từ file CSV."
                       Foreground="Gray" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Xuất PDF..." Style="{StaticResource NutPhu}" Margin="0,0,8,0"
                        Click="btnXuatPdf_Click" />
                <Button Content="Xuất file mẫu..." Style="{StaticResource NutPhu}" Margin="0,0,8,0"
                        Click="btnXuatMau_Click" />
                <Button Content="Nhập từ file CSV..." Style="{StaticResource NutPhu}"
                        Click="btnNhapFile_Click" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" x:Name="dgDiem"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionUnit="Cell"
                  AlternatingRowBackground="#F7F9FC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SV" Binding="{Binding MaSV}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Điểm giữa kỳ" Binding="{Binding DiemGiuaKy}" Width="120" />
                <DataGridTextColumn Header="Điểm cuối kỳ" Binding="{Binding DiemCuoiKy}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="lblThongBao"
                       Foreground="{StaticResource MauNguyHiem}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Đóng" Style="{StaticResource NutPhu}" Width="100" Margin="0,0,8,0"
                        Click="btnDong_Click" />
                <Button Content="Lưu tất cả" Style="{StaticResource NutChinh}" Width="120"
                        Click="btnLuuTatCa_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
